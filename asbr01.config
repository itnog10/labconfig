        unit 0 {
            family inet {
                address 63.216.92.196/27;
            }
            family inet6 {
                dhcpv6-client {
                    client-type stateful;
                    client-ia-type ia-na;
                    client-identifier duid-type duid-ll;
                    vendor-id Juniper:mx204:GP900;
                }
