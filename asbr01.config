    mgmt_junos {
        routing-options {
            static {
                route 0.0.0.0/0 next-hop 63.216.92.193;
            }
        }
        description Management;
    }
}
routing-options {
    router-id 63.216.92.254;
    autonomous-system 57402;
}
protocols {
    router-advertisement {
        interface fxp0.0 {
            managed-configuration;
        }
    }
    bgp {
        group internal-peers {
            type internal;
            description "iBGP F1A";
            local-address 63.216.92.254;
            import accept-all;
            export accept-all;
            neighbor 63.216.92.255;
        }
        local-as 57402;
    }
    ospf {
        area 0.0.0.0 {
            interface lo0.0 {
                passive;
            }
            interface xe-0/1/1.0;
        }
    }
}